    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\n// Slack URL verification\nif (body.type === 'url_verification') {\n  return [{ json: { _type: 'challenge', challenge: body.challenge } }];\n}\n\n// /rfp slash command — just a flag, no action needed\nif (body.command === '/rfp') {\n  return [{\n    json: {\n      _type: 'slash',\n      user: body.user_id || '',\n      channel: body.channel_id || '',\n      response_url: body.response_url || ''\n    }\n  }];\n}\n\n// file_shared event — this is where the work happens\nif (body.type === 'event_callback') {\n  const ev = body.event || {};\n  if (ev.type === 'file_shared') {\n    return [{\n      json: {\n        _type: 'file_shared',\n        file_id: ev.file_id || (ev.file && ev.file.id) || null,\n        user: ev.user_id || ev.user || null,\n        channel: ev.channel_id || ev.channel || null\n      }\n    }];\n  }\n}\n\nreturn [{ json: { _type: 'unknown' } }];"
      },
      "id": "c4c9f018-7e05-4f9c-b016-0ff2b5eb2f5a",

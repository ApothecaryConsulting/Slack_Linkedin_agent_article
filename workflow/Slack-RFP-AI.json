    {
      "parameters": {
        "jsCode": "const fileInfo = $('Get File Info').first().json.file;\nconst slashData = $('Parse Slack Event').first().json;\nconst rfpText = $('Extract Document Text').first().json.text || '';\nconst capText = $('Extract Capability Statement Text').first().json.text || '';\n\nreturn [{\n  json: {\n    file_name: fileInfo.name,\n    file_id: fileInfo.id,\n    uploader_user: slashData.user || fileInfo.user,\n    extracted_text: rfpText,\n    capability_statement: capText\n  }\n}];"
      },
      "id": "4a75faa4-9696-40fc-8188-4d00a7058ee8",
      "name": "Prepare PDF for OpenAI",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3312,
        1344
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4.1-mini\",\n  \"max_tokens\": 2000,\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert at analyzing RFPs and matching them against company capability statements. When given an RFP and a capability statement, provide:\\n\\n**RFP Summary**\\n1. *Project Overview* — What is being requested\\n2. *Key Requirements* — The most important requirements\\n3. *Deadlines* — Submission deadline and key dates\\n4. *Scope of Work* — What work needs to be performed\\n5. *Evaluation Criteria* — How proposals will be scored\\n\\n**Capability Match Analysis**\\n6. *Strengths* — Where our capability statement strongly aligns with the RFP\\n7. *Gaps* — Where we may fall short or lack evidence\\n8. *Missing Certifications or Insurance* — List any certifications, clearances, licenses, or insurance requirements in the RFP that are not present in our capability statement. If none are missing, say None.\\n\\n**Pursuit Score**\\n9. *Score* — Give a score out of 100. Breakdown: capability alignment (40pts), past performance relevance (20pts), likelihood of winning (20pts), deduct up to 20pts for gaps and missing requirements. Show the breakdown.\\n10. *Recommendation* — Yes / No / Maybe and one sentence reason.\\n\\nKeep the summary practical and actionable. Use bullet points where helpful.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify('RFP Document: ' + $json.file_name + '\\n\\n' + $json.extracted_text + '\\n\\n---\\n\\nOur Capability Statement:\\n\\n' + $json.capability_statement) }}\n    }\n  ]\n}",
        "options": {}
      },
      "id": "d5c60747-e694-4409-8312-f2566b9606aa",
      "name": "OpenAI: Summarize RFP",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        3520,
        1344
      ],
      "credentials": {
        "openAiApi": {
          "id": "eaCC4e5jH2cVYm8b",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst inputData = $('Prepare PDF for OpenAI').first().json;\n\nconst summary = response.choices?.[0]?.message?.content || 'No summary returned from OpenAI.';\n\nreturn [{\n  json: {\n    summary,\n    file_name: inputData.file_name,\n    uploader_user: inputData.uploader_user\n  }\n}];"
      },

# n8n runtime
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Required for credential encryption — set once, do not change after first run
N8N_ENCRYPTION_KEY=REPLACE_WITH_RANDOM_32_CHAR_STRING

# Webhook URL — only required when ngrok.enabled is true in config.json
# Update this each time your ngrok domain changes
WEBHOOK_URL=https://YOUR_NGROK_DOMAIN

# Slack channel IDs (not names) — find via Slack channel settings
LOG_CHANNEL_ID=C012ABCDEF
APPROVAL_CHANNEL_ID=C045XYZ123

# OpenAI
OPENAI_MODEL=gpt-4.1-mini

# LinkedIn author URN — personal posting
LINKEDIN_AUTHOR_URN=urn:li:person:XXXXXXXX

# LinkedIn org URN — company posting (optional)
# LINKEDIN_ORG_URN=urn:li:organization:XXXXXXXX
